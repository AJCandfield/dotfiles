Host github.com
  Hostname github.com
  User git
  IdentityFile ~/.ssh/github-keyless-key

Host gitlab.com
  Hostname gitlab.com
  User git
  IdentityFile ~/.ssh/my-private-gitlab

Host i-* mi-*

  ProxyCommand sh -c "aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters 'portNumber=%p'"
